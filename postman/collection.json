{
  "info": {
    "name": "Task Time Tracker API - Full Suite",
    "description": "Коллекция запросов для тестирования всех сценариев: успех, ошибки валидации и безопасность.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth - Get Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/auth/token?username=admin",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "token"],
          "query": [{ "key": "username", "value": "admin" }]
        },
        "description": "ПОЛУЧЕНИЕ ТОКЕНА: вставь в вкладку Authorization коллекции (тип Bearer Token)."
      }
    },
    {
      "name": "Success Cases",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Изучить Docker-compose\",\n  \"description\": \"Разобраться с объемами (volumes) и сетями\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "http://localhost:8080/api/task",
            "description": "УСПЕХ: Создание новой задачи. Должно вернуть статус 200 и ID."
          }
        },
        {
          "name": "Add Time Record",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 55,\n  \"taskId\": 1,\n  \"startTime\": \"2026-05-02T10:00:00\",\n  \"endTime\": \"2026-05-02T12:00:00\",\n  \"description\": \"Работа над проектом\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "http://localhost:8080/api/time-records",
            "description": "УСПЕХ: Добавление 120 минут работы. Убедись, что taskId существует."
          }
        },
        {
          "name": "Get Employee Total Time",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/time-records/employee/55/total?startTime=2026-05-01T00:00:00&endTime=2026-05-03T23:59:59",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "time-records", "employee", "55", "total"],
              "query": [
                { "key": "startTime", "value": "2026-05-01T00:00:00" },
                { "key": "endTime", "value": "2026-05-03T23:59:59" }
              ]
            },
            "description": "УСПЕХ: Получение суммы минут за период."
          }
        }
      ]
    },
    {
      "name": "Validation Errors (400)",
      "item": [
        {
          "name": "Error - Empty Title",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"description\": \"Забыли название\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "http://localhost:8080/api/task",
            "description": "ОШИБКА 400: Нельзя создать задачу без заголовка."
          }
        },
        {
          "name": "Error - Wrong Time Order",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 55,\n  \"taskId\": 1,\n  \"startTime\": \"2026-05-02T15:00:00\",\n  \"endTime\": \"2026-05-02T10:00:00\",\n  \"description\": \"Конец раньше начала\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "http://localhost:8080/api/time-records",
            "description": "ОШИБКА 400: Логическая ошибка в датах."
          }
        }
      ]
    },
    {
      "name": "Not Found Errors (404)",
      "item": [
        {
          "name": "Error - Task Not Found",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 55,\n  \"taskId\": 9999,\n  \"startTime\": \"2026-05-02T10:00:00\",\n  \"endTime\": \"2026-05-02T11:00:00\",\n  \"description\": \"К несуществующей задаче\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "http://localhost:8080/api/time-records",
            "description": "ОШИБКА 404: Попытка добавить время к задаче, которой нет в базе."
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "ВСТАВЬ_ТОКЕН_СЮДА",
        "type": "string"
      }
    ]
  }
